# Gemini API (Required for all AI services)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Authentication
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRE_MINUTES=10080

# PostgreSQL Database (matches docker-compose defaults)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=wardrobe
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/wardrobe

# Redis (matches docker-compose defaults)
REDIS_URL=redis://redis:6379/0

# Qdrant Vector Store (matches docker-compose defaults)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=garments

# Storage
MEDIA_ROOT=/app/media
MAX_UPLOAD_SIZE_MB=20

# Development Mode (True to mock external AI API calls for testing/designing)
DEV_MODE=false
